                ],
                "summary": "Realizar login",
                "operationId": "da8f8ff1fa5d1372c4d4cf638a7bd39f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
